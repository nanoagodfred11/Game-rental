# MongoDB
# Local (Docker Compose): mongodb://mongo:27017/gaming_rental
# Production (Atlas):     mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/gaming_rental
MONGODB_URL=mongodb://mongo:27017/gaming_rental
DATABASE_NAME=gaming_rental

# Session secret (change this to a random string)
SECRET_KEY=your-secret-key-change-this-to-a-random-string

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changethispassword123

# Business Settings
HOURLY_RATE=70
MIN_BOOKING_HOURS=2
MAX_BOOKING_HOURS=6
MAX_TOTAL_HOURS=10

# MTN Mobile Money
MOMO_NUMBER=0592005318
MOMO_NAME=NANOA GODFRED

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Node environment
NODE_ENV=development
