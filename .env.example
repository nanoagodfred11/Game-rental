# MongoDB Atlas Connection
# Get this from MongoDB Atlas Dashboard > Connect > Drivers
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/gaming_rental?retryWrites=true&w=majority

# Database Name
DATABASE_NAME=gaming_rental

# JWT Secret Key (generate a random string - keep this secret!)
# You can generate one at: https://generate-secret.vercel.app/32
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Business Settings
HOURLY_RATE=100
CURRENCY=GHS
MIN_BOOKING_HOURS=2
MAX_BOOKING_HOURS=6

# MTN Mobile Money Details
MOMO_NUMBER=0592005318
MOMO_NAME=NANOA GODFRED

# Admin credentials (REQUIRED - must be changed!)
# Password must be at least 12 characters and not a common password
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123!
